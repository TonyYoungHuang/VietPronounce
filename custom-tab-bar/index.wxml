<view class="tab-shell">
  <view class="tab-bar">
    <block wx:for="{{list}}" wx:key="pagePath">
      <view
        class="tab-item {{selected === index ? 'tab-item--active' : ''}}"
        data-path="{{item.pagePath}}"
        data-index="{{index}}"
        bindtap="switchTab"
      >
        <view class="tab-icon tab-icon--{{item.icon}}"></view>
        <text class="tab-label">{{item.text}}</text>
      </view>
    </block>
  </view>
</view>
