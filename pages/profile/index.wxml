<view class="sanctuary-page with-tabbar page-profile">
  <view class="topbar">
    <view class="avatar-shell">
      <view class="avatar-shell__core">{{avatarText}}</view>
    </view>
    <view class="topbar-spacer"></view>
    <view class="topbar-action" bindtap="goDialect">⚙</view>
  </view>

  <view class="container topbar-offset page-profile__content">
    <view class="profile-hero">
      <view class="profile-avatar">
        <view class="profile-avatar__core"></view>
      </view>
      <view class="profile-title">你好，{{nickName}}</view>
      <view class="profile-subtitle">使用激活码开通课程后，练习进度会保存到当前学习档案。</view>
      <button class="btn-secondary profile-cta" bindtap="goLevels">继续课程</button>
    </view>

    <view class="surface-card profile-card">
      <view class="profile-card__head">
        <view>
          <view class="section-title">课程权益</view>
          <view class="section-subtitle">{{product.unlocked ? '完整训练路径已解锁。' : '输入激活码后解锁完整课程与复练路径。'}}</view>
        </view>
        <view class="{{product.unlocked ? 'badge-success' : 'badge-warn'}}">{{product.unlocked ? '已激活' : '待激活'}}</view>
      </view>
      <button class="btn-primary mt-32" wx:if="{{!product.unlocked}}" bindtap="goRedeem">输入激活码</button>
    </view>

    <view class="section-head profile-section-head">
      <view class="section-title">发音体系</view>
      <view class="section-link" bindtap="goDialect">切换</view>
    </view>

    <view class="profile-dialect-grid">
      <block wx:for="{{dialects}}" wx:key="id">
        <view class="surface-wrap profile-dialect-card {{selectedDialect === item.id ? 'profile-dialect-card--active' : ''}}" data-dialect="{{item.id}}" bindtap="switchDialect">
          <view class="profile-dialect-card__name">{{item.name}}</view>
          <view class="profile-dialect-card__meta">{{item.meta}}</view>
          <view class="profile-dialect-card__copy">{{item.description}}</view>
        </view>
      </block>
    </view>
  </view>
</view>
