<view class="sanctuary-page with-tabbar page-profile">
  <view class="topbar">
    <view class="avatar-shell">
      <view class="avatar-shell__core">{{avatarText}}</view>
    </view>
    <view class="topbar-spacer"></view>
    <view class="topbar-action" bindtap="goDialect">⚙</view>
  </view>

  <view class="container topbar-offset page-profile__content">
    <view class="profile-hero">
      <view class="profile-avatar">
        <view class="profile-avatar__core"></view>
      </view>
      <view class="profile-title">你好，{{nickName}}</view>
      <view class="profile-subtitle">{{auth.loggedIn ? '学习进度会持续为您保存。' : '登录后可保存进度并激活完整课程。'}}</view>
      <button class="btn-primary profile-cta" wx:if="{{!auth.loggedIn}}" bindtap="goLogin">立即登录</button>
      <button class="btn-secondary profile-cta" wx:else bindtap="goLevels">继续课程</button>
    </view>

    <view class="surface-card profile-card">
      <view class="profile-card__head">
        <view>
          <view class="section-title">高级课程</view>
          <view class="section-subtitle">{{product.unlocked ? '北越与南越完整体系已解锁。' : '激活后解锁完整课程与复练路径。'}}</view>
        </view>
        <view class="{{product.unlocked ? 'badge-success' : 'badge-warn'}}">{{product.unlocked ? '已激活' : '待激活'}}</view>
      </view>
      <button class="btn-primary mt-32" wx:if="{{!product.unlocked}}" bindtap="goRedeem">激活高级课程</button>
      <button class="btn-secondary mt-24" bindtap="goContact">联系顾问</button>
    </view>

    <view class="section-head profile-section-head">
      <view class="section-title">发音体系</view>
      <view class="section-link" bindtap="goDialect">切换</view>
    </view>

    <view class="profile-dialect-grid">
      <block wx:for="{{dialects}}" wx:key="id">
        <view class="surface-wrap profile-dialect-card {{selectedDialect === item.id ? 'profile-dialect-card--active' : ''}}" data-dialect="{{item.id}}" bindtap="switchDialect">
          <view class="profile-dialect-card__name">{{item.name}}</view>
          <view class="profile-dialect-card__meta">{{item.meta}}</view>
          <view class="profile-dialect-card__copy">{{item.description}}</view>
        </view>
      </block>
      <view wx:if="{{false}}" class="surface-wrap profile-dialect-card {{selectedDialect === 'north' ? 'profile-dialect-card--active' : ''}}" data-dialect="north" bindtap="switchDialect">
        <view class="profile-dialect-card__name">北越</view>
        <view class="profile-dialect-card__meta">NORTHERN</view>
        <view class="profile-dialect-card__copy">标准感更强，声调边界清晰。</view>
      </view>
      <view wx:if="{{false}}" class="surface-wrap profile-dialect-card {{selectedDialect === 'south' ? 'profile-dialect-card--active' : ''}}" data-dialect="south" bindtap="switchDialect">
        <view class="profile-dialect-card__name">南越</view>
        <view class="profile-dialect-card__meta">SOUTHERN</view>
        <view class="profile-dialect-card__copy">语流更顺，口感更自然。</view>
      </view>
    </view>
  </view>
</view>
