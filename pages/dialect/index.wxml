<view class="sanctuary-page page-dialect">
  <view class="topbar">
    <view class="avatar-shell" bindtap="goProfile">
      <view class="avatar-shell__core">{{avatarText}}</view>
    </view>
    <view class="topbar-spacer"></view>
    <view class="topbar-action" bindtap="goProfile">⚙</view>
  </view>

  <view class="container topbar-offset page-dialect__content">
    <view class="dialect-hero">
      <view class="hero-display">选择您的<br />学习语言</view>
      <view class="body-copy">开启一段东南亚文化的探索之旅。从这里开始。</view>
    </view>

    <view class="surface-card dialect-feature-card">
      <view class="dialect-feature-badge">NEW / 新课程</view>
      <view class="dialect-feature-head">
        <view>
          <view class="dialect-feature-title">越南语</view>
          <view class="dialect-feature-sub">Tiếng Việt</view>
        </view>
        <view class="dialect-feature-leaf"></view>
      </view>

      <view class="dialect-feature-actions">
        <block wx:for="{{dialects}}" wx:key="id">
          <view
            class="dialect-option {{selectedDialect === item.id ? 'dialect-option--active' : ''}}"
            data-dialect="{{item.id}}"
            bindtap="chooseDialect"
          >
            <view class="dialect-option__name">{{item.name}}</view>
            <view class="dialect-option__meta">{{item.id === 'north' ? 'NORTHERN' : 'SOUTHERN'}}</view>
            <button class="dialect-option__listen" data-dialect="{{item.id}}" catchtap="previewAudio">试听</button>
          </view>
        </block>
      </view>

      <button class="btn-primary dialect-start" bindtap="startTrial"><view class="btn-glyph btn-glyph--record"></view><text>开始免费试练</text></button>
    </view>

    <view class="dialect-grid">
      <block wx:for="{{otherLanguages}}" wx:key="name">
        <view
          class="surface-card dialect-mini-card {{selectedDialect === item.id ? 'dialect-mini-card--active' : ''}}"
          data-dialect="{{item.id}}"
          bindtap="chooseLanguage"
        >
          <view class="dialect-mini-icon dialect-mini-icon--{{item.tone}}">
            <view class="mini-symbol mini-symbol--{{item.icon}}"></view>
          </view>
          <view class="dialect-mini-name">{{item.name}}</view>
          <view class="dialect-mini-sub">{{item.sub}}</view>
          <view class="dialect-mini-cta">开始试练</view>
        </view>
      </block>
    </view>

    <view class="dialect-quote-card">
      <view class="dialect-quote-card__art"></view>
      <view class="dialect-quote-card__mask"></view>
      <view class="dialect-quote-card__text">“语言是开启另一种生活的钥匙。”</view>
    </view>
  </view>

  <view class="page-dock">
    <view class="page-dock__item" bindtap="goHome">
      <view class="dock-icon dock-icon--home"></view>
      <view class="page-dock__label">首页</view>
    </view>
    <view class="page-dock__item page-dock__item--active">
      <view class="dock-icon dock-icon--book"></view>
      <view class="page-dock__label">课程</view>
    </view>
    <view class="page-dock__item" bindtap="goProfile">
      <view class="dock-icon dock-icon--person"></view>
      <view class="page-dock__label">个人</view>
    </view>
  </view>
</view>
