.landing-page {
  overflow: hidden;
}

.landing-content {
  padding-bottom: 112rpx;
}

.landing-page .topbar {
  height: 76rpx;
  padding-top: 8rpx;
  padding-bottom: 8rpx;
  background: rgba(235, 249, 242, 0.72);
}

.landing-page .avatar-shell,
.landing-page .topbar-action {
  width: 54rpx;
  height: 54rpx;
}

.landing-page .avatar-shell__core {
  width: 46rpx;
  height: 46rpx;
}

.landing-page .topbar-gear::before {
  width: 30rpx;
  height: 30rpx;
  border-width: 7rpx;
}

.landing-content.topbar-offset {
  padding-top: 0;
}

.landing-content.container {
  padding-top: 0;
}

.landing-topbar-title {
  position: absolute;
  left: 132rpx;
  right: 132rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #191c1b;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
}

.topbar-gear {
  position: relative;
}

.topbar-gear::before {
  content: '';
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 8rpx dotted #006b47;
}

.topbar-gear::after {
  content: '';
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #006b47;
}

.landing-hero {
  position: relative;
  padding: 0 0 2rpx;
  margin-top: 18rpx;
}

.landing-hero__leaf,
.landing-hero__orb {
  position: absolute;
  pointer-events: none;
}

.landing-hero__leaf {
  border-radius: 90rpx 0 90rpx 90rpx;
  transform: rotate(45deg);
  opacity: 0.18;
}

.landing-hero__leaf--one {
  right: -28rpx;
  top: 54rpx;
  width: 118rpx;
  height: 142rpx;
  background: #00875a;
}

.landing-hero__leaf--two {
  left: -62rpx;
  bottom: 8rpx;
  width: 94rpx;
  height: 112rpx;
  background: #895100;
  opacity: 0.1;
}

.landing-hero__orb {
  border-radius: 50%;
  background: radial-gradient(circle, rgba(141, 247, 193, 0.28), rgba(141, 247, 193, 0));
}

.landing-hero__orb--one {
  right: -90rpx;
  top: -28rpx;
  width: 260rpx;
  height: 260rpx;
}

.landing-hero__orb--two {
  left: -120rpx;
  bottom: -88rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255, 220, 188, 0.32), rgba(255, 220, 188, 0));
}

.landing-eyebrow {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  gap: 14rpx;
  color: #895100;
  font-size: 24rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  margin-bottom: 10rpx;
}

.landing-eyebrow__icon {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #f2e4d4;
}

.landing-eyebrow__icon::before {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 10rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #895100;
}

.landing-eyebrow__icon::after {
  content: '';
  position: absolute;
  right: -6rpx;
  top: 6rpx;
  width: 10rpx;
  height: 18rpx;
  border-radius: 0 12rpx 12rpx 0;
  border-right: 5rpx solid #895100;
}

.landing-title,
.landing-copy,
.landing-actions {
  position: relative;
  z-index: 1;
}

.landing-copy {
  max-width: 620rpx;
  margin-top: 16rpx;
}

.landing-actions {
  display: grid;
  gap: 16rpx;
  margin-top: 24rpx;
}

.landing-language-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.landing-language-card {
  position: relative;
  min-height: 154rpx;
  padding: 22rpx 22rpx 20rpx;
  border-radius: 34rpx;
  display: grid;
  grid-template-columns: 62rpx 1fr;
  gap: 14rpx;
  align-items: start;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(0, 107, 71, 0.12);
  box-shadow: 0 18rpx 42rpx rgba(25, 28, 27, 0.06);
}

.landing-language-card--active {
  border-color: rgba(0, 135, 90, 0.58);
  box-shadow: 0 24rpx 56rpx rgba(0, 107, 71, 0.16);
}

.landing-language-card__icon {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  color: #006b47;
  background: #dff0e8;
}

.landing-language-card--warm .landing-language-card__icon { color: #895100; background: #f3e5d3; }
.landing-language-card--cool .landing-language-card__icon { color: #006b47; background: #dcefe9; }
.landing-language-card--leaf .landing-language-card__icon { color: #007a55; background: #d9f7e7; }
.landing-language-card--mint .landing-language-card__icon { color: #007a55; background: #cdf8de; }

.landing-language-card__name {
  color: #191c1b;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.2;
  padding-right: 8rpx;
}

.landing-language-card__sub {
  margin-top: 6rpx;
  color: #59675f;
  font-size: 22rpx;
  line-height: 1.3;
}

.landing-language-card__badge {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  min-width: 82rpx;
  height: 46rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #007a55;
  background: rgba(0, 135, 90, 0.1);
  font-size: 20rpx;
  font-weight: 900;
}

.mini-symbol {
  position: relative;
  color: inherit;
}

.mini-symbol::before,
.mini-symbol::after {
  content: '';
  position: absolute;
  background: currentColor;
}

.mini-symbol--leaf::before,
.mini-symbol--river::before {
  left: 19rpx;
  top: 14rpx;
  width: 24rpx;
  height: 31rpx;
  border-radius: 34rpx 0 34rpx 34rpx;
  transform: rotate(45deg);
}

.mini-symbol--river::after {
  left: 15rpx;
  bottom: 13rpx;
  width: 33rpx;
  height: 8rpx;
  border-radius: 999rpx;
  opacity: 0.35;
}

.mini-symbol--temple::before {
  left: 15rpx;
  right: 15rpx;
  top: 31rpx;
  height: 18rpx;
  border-radius: 3rpx;
}

.mini-symbol--temple::after {
  left: 12rpx;
  top: 15rpx;
  width: 0;
  height: 0;
  background: transparent;
  border-left: 19rpx solid transparent;
  border-right: 19rpx solid transparent;
  border-bottom: 18rpx solid currentColor;
}

.mini-symbol--city::before {
  left: 19rpx;
  bottom: 14rpx;
  width: 26rpx;
  height: 30rpx;
  border-radius: 3rpx;
}

.mini-symbol--city::after {
  left: 25rpx;
  top: 22rpx;
  width: 6rpx;
  height: 6rpx;
  box-shadow: 12rpx 0 0 #fff, 0 11rpx 0 #fff, 12rpx 11rpx 0 #fff;
  background: #fff;
}

.mini-symbol--boat::before {
  left: 15rpx;
  bottom: 17rpx;
  width: 33rpx;
  height: 14rpx;
  border-radius: 0 0 20rpx 20rpx;
}

.mini-symbol--boat::after {
  left: 27rpx;
  top: 14rpx;
  width: 0;
  height: 0;
  background: transparent;
  border-top: 14rpx solid transparent;
  border-bottom: 14rpx solid transparent;
  border-left: 19rpx solid currentColor;
}

.landing-activate {
  margin-top: 24rpx;
  padding: 30rpx 28rpx 30rpx;
  border-radius: 38rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.landing-activate__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.landing-activate__eyebrow {
  color: #895100;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 3rpx;
}

.landing-activate__title {
  margin-top: 8rpx;
  color: #191c1b;
  font-size: 30rpx;
  font-weight: 900;
}

.landing-activate__chip {
  min-width: 72rpx;
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #895100;
  background: #ffe1bf;
  font-size: 20rpx;
  font-weight: 900;
}

.landing-activate__selected {
  margin-top: 16rpx;
  color: #007a55;
  font-size: 24rpx;
  font-weight: 800;
}

.landing-activate__form {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
  margin-top: 22rpx;
  width: 100%;
  box-sizing: border-box;
}

.landing-activate__input {
  height: 82rpx;
  min-width: 0;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: #eef3f0;
  color: #191c1b;
  font-size: 26rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.landing-activate__placeholder {
  color: rgba(89, 103, 95, 0.58);
}

.landing-activate__button {
  height: 72rpx;
  width: 188rpx;
  min-width: 0;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: #00875a;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 72rpx;
  box-sizing: border-box;
  justify-self: end;
}

.landing-activate__button::after {
  border: none;
}

.landing-activate__message {
  margin-top: 16rpx;
  color: #895100;
  font-size: 22rpx;
  line-height: 1.45;
}

.sanctuary-cta {
  min-height: 104rpx;
  padding: 0 38rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  font-size: 30rpx;
  font-weight: 900;
  box-shadow: 0 24rpx 56rpx rgba(25, 28, 27, 0.08);
}

.sanctuary-cta--primary {
  color: #ffffff;
  background-color: #00875a;
  background-image: linear-gradient(135deg, #006b47 0%, #00875a 100%);
}

.sanctuary-cta--secondary {
  color: #006b47;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(16px);
}

.cta-arrow,
.cta-book {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  color: currentColor;
}

.cta-arrow::before {
  content: '';
  position: absolute;
  left: 6rpx;
  top: 14rpx;
  width: 22rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: currentColor;
}

.cta-arrow::after {
  content: '';
  position: absolute;
  right: 4rpx;
  top: 8rpx;
  width: 14rpx;
  height: 14rpx;
  border: solid currentColor;
  border-width: 0 6rpx 6rpx 0;
  transform: rotate(-45deg);
}

.cta-book::before,
.cta-book::after {
  content: '';
  position: absolute;
  top: 5rpx;
  width: 15rpx;
  height: 24rpx;
  border-radius: 4rpx 10rpx 10rpx 4rpx;
  background: currentColor;
}

.cta-book::before {
  left: 1rpx;
}

.cta-book::after {
  right: 1rpx;
  opacity: 0.62;
}

.landing-scenery {
  position: relative;
  height: 166rpx;
  margin-top: 34rpx;
  border-radius: 34rpx;
  overflow: hidden;
  box-shadow: 0 34rpx 88rpx rgba(25, 28, 27, 0.12);
  background:
    radial-gradient(circle at 22% 28%, rgba(141, 247, 193, 0.44), transparent 19%),
    linear-gradient(135deg, #102c20 0%, #0d7d55 48%, #9cc8a8 100%);
}

.landing-scenery__sun {
  position: absolute;
  left: 64rpx;
  top: 34rpx;
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(141, 247, 193, 0.54), rgba(141, 247, 193, 0));
}

.landing-scenery__mountain {
  position: absolute;
  bottom: 22rpx;
  width: 420rpx;
  height: 180rpx;
  border-radius: 58% 42% 0 0;
}

.landing-scenery__mountain--left {
  left: -170rpx;
  background: rgba(5, 67, 43, 0.82);
}

.landing-scenery__mountain--right {
  right: -150rpx;
  background: rgba(43, 112, 76, 0.72);
}

.landing-scenery__river {
  position: absolute;
  left: 230rpx;
  right: 210rpx;
  bottom: -78rpx;
  height: 184rpx;
  border-radius: 50% 50% 0 0;
  background: rgba(226, 246, 235, 0.5);
  transform: skewX(-18deg);
}

.landing-scenery__leaf {
  position: absolute;
  width: 86rpx;
  height: 112rpx;
  border-radius: 80rpx 0 80rpx 80rpx;
  background: rgba(141, 247, 193, 0.5);
  transform: rotate(45deg);
}

.landing-scenery__leaf--left {
  left: 28rpx;
  bottom: 16rpx;
}

.landing-scenery__leaf--right {
  right: 62rpx;
  top: 24rpx;
  width: 68rpx;
  height: 90rpx;
  opacity: 0.38;
}

.landing-scenery__mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.08), rgba(0, 48, 31, 0.6));
}

.landing-scenery__quote {
  position: absolute;
  left: 38rpx;
  right: 38rpx;
  bottom: 26rpx;
  color: #fff7df;
  font-size: 31rpx;
  line-height: 1.28;
  font-weight: 900;
  font-style: italic;
  text-shadow: 0 5rpx 16rpx rgba(0, 25, 16, 0.42);
}

.landing-metrics {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24rpx;
  margin-top: 28rpx;
}

.landing-metric {
  position: relative;
  min-height: 214rpx;
  padding: 34rpx 30rpx 28rpx;
  overflow: hidden;
  border-radius: 40rpx;
}

.landing-metric::after {
  content: '';
  position: absolute;
  right: -42rpx;
  top: -40rpx;
  width: 124rpx;
  height: 124rpx;
  border-radius: 50%;
  background: rgba(0, 107, 71, 0.08);
}

.landing-metric__icon {
  margin-bottom: 22rpx;
}

.metric-icon,
.flow-icon {
  position: relative;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  color: #006b47;
  background: #dff0e8;
}

.metric-icon::before,
.metric-icon::after {
  content: '';
  position: absolute;
  background: currentColor;
}

.metric-icon--score::before {
  left: 17rpx;
  bottom: 15rpx;
  width: 7rpx;
  height: 18rpx;
  border-radius: 7rpx;
  box-shadow: 10rpx -8rpx 0 currentColor, 20rpx -16rpx 0 currentColor;
}

.metric-icon--score::after {
  right: 10rpx;
  top: 10rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #895100;
}

.metric-icon--path::before {
  left: 16rpx;
  top: 12rpx;
  width: 26rpx;
  height: 34rpx;
  border-radius: 26rpx 0 26rpx 26rpx;
  transform: rotate(45deg);
}

.metric-icon--path::after {
  left: 27rpx;
  top: 24rpx;
  width: 5rpx;
  height: 22rpx;
  border-radius: 5rpx;
  background: #ffffff;
  transform: rotate(45deg);
}

.landing-metric__value {
  color: #191c1b;
  font-size: 50rpx;
  font-weight: 900;
}

.landing-metric__label {
  margin-top: 12rpx;
  color: #3e4942;
  font-size: 23rpx;
  line-height: 1.45;
}

.landing-section-head {
  margin-top: 84rpx;
}

.landing-flow {
  display: grid;
  gap: 28rpx;
}

.landing-flow__item {
  position: relative;
  min-height: 228rpx;
  padding: 36rpx 40rpx 34rpx;
  border-radius: 44rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(0, 107, 71, 0.14);
  box-shadow: 0 26rpx 72rpx rgba(25, 28, 27, 0.08);
}

.landing-flow__item::after {
  content: '';
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  bottom: 26rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #00875a 0%, rgba(0, 107, 71, 0.12) 100%);
}

.landing-flow__item::before {
  content: '';
  position: absolute;
  right: 36rpx;
  bottom: 34rpx;
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: #00875a;
  box-shadow: 0 14rpx 30rpx rgba(0, 107, 71, 0.18);
}

.landing-flow__watermark {
  position: absolute;
  right: 18rpx;
  bottom: 18rpx;
  width: 190rpx;
  height: 170rpx;
  opacity: 0.48;
}

.landing-flow__icon {
  position: absolute;
  right: 38rpx;
  top: 34rpx;
  z-index: 2;
  opacity: 1;
}

.flow-icon__book-left,
.flow-icon__book-right {
  position: absolute;
  top: 16rpx;
  width: 16rpx;
  height: 26rpx;
  border-radius: 4rpx 12rpx 12rpx 4rpx;
  background: #00875a;
}

.flow-icon__book-left {
  left: 12rpx;
}

.flow-icon__book-right {
  right: 12rpx;
  opacity: 0.72;
}

.flow-icon__mic-head {
  position: absolute;
  left: 20rpx;
  top: 10rpx;
  width: 18rpx;
  height: 30rpx;
  border-radius: 12rpx;
  background: #00875a;
}

.flow-icon__mic-stand {
  position: absolute;
  left: 17rpx;
  bottom: 10rpx;
  width: 24rpx;
  height: 14rpx;
  border-radius: 0 0 16rpx 16rpx;
  border: 5rpx solid #00875a;
  border-top: none;
}

.flow-icon__lock-body {
  position: absolute;
  left: 17rpx;
  top: 27rpx;
  width: 24rpx;
  height: 22rpx;
  border-radius: 7rpx;
  background: #00875a;
}

.flow-icon__lock-arc {
  position: absolute;
  left: 19rpx;
  top: 12rpx;
  width: 20rpx;
  height: 18rpx;
  border: 5rpx solid #00875a;
  border-bottom: none;
  border-radius: 18rpx 18rpx 0 0;
}

.flow-watermark__book-left,
.flow-watermark__book-right {
  position: absolute;
  top: 42rpx;
  width: 62rpx;
  height: 92rpx;
  border-radius: 12rpx 38rpx 38rpx 12rpx;
  background: #dfd8cb;
}

.flow-watermark__book-left {
  left: 32rpx;
}

.flow-watermark__book-right {
  right: 28rpx;
  opacity: 0.72;
}

.flow-watermark__leaf {
  position: absolute;
  right: 18rpx;
  top: 14rpx;
  width: 44rpx;
  height: 58rpx;
  border-radius: 50rpx 0 50rpx 50rpx;
  background: #00875a;
  transform: rotate(45deg);
}

.flow-watermark__mic-head {
  position: absolute;
  left: 76rpx;
  top: 26rpx;
  width: 42rpx;
  height: 78rpx;
  border-radius: 28rpx;
  background: #dfd8cb;
}

.flow-watermark__mic-stand {
  position: absolute;
  left: 64rpx;
  top: 96rpx;
  width: 66rpx;
  height: 34rpx;
  border-radius: 0 0 42rpx 42rpx;
  border: 14rpx solid #dfd8cb;
  border-top: none;
}

.flow-watermark__sound {
  position: absolute;
  border-radius: 0 70rpx 70rpx 0;
  border-right: 12rpx solid #00875a;
  background: transparent;
}

.flow-watermark__sound--one {
  right: 26rpx;
  top: 44rpx;
  width: 44rpx;
  height: 66rpx;
}

.flow-watermark__sound--two {
  right: 2rpx;
  top: 30rpx;
  width: 74rpx;
  height: 96rpx;
  opacity: 0.54;
}

.flow-watermark__lock-body {
  position: absolute;
  left: 58rpx;
  top: 76rpx;
  width: 84rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: #dfd8cb;
}

.flow-watermark__lock-arc {
  position: absolute;
  left: 72rpx;
  top: 32rpx;
  width: 54rpx;
  height: 58rpx;
  border: 18rpx solid #dfd8cb;
  border-bottom: none;
  border-radius: 48rpx 48rpx 0 0;
}

.flow-watermark__spark {
  position: absolute;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #00875a;
}

.flow-watermark__spark--one {
  right: 26rpx;
  top: 34rpx;
}

.flow-watermark__spark--two {
  right: 48rpx;
  bottom: 32rpx;
  width: 12rpx;
  height: 12rpx;
}

.landing-flow__num {
  color: #895100;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 3rpx;
}

.landing-flow__title {
  margin-top: 40rpx;
  color: #191c1b;
  font-size: 34rpx;
  font-weight: 900;
  padding-right: 190rpx;
}

.landing-flow__copy {
  max-width: 440rpx;
  margin-top: 12rpx;
  color: #3e4942;
  font-size: 25rpx;
  line-height: 1.55;
  padding-right: 76rpx;
}
