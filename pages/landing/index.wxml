<view class="sanctuary-page landing-page">
  <view class="topbar">
    <view class="avatar-shell">
      <view class="avatar-shell__core">V</view>
    </view>
    <view class="landing-topbar-title">每天练一点，发音准一点</view>
  </view>

  <view class="container topbar-offset landing-content">
    <view class="landing-hero">
      <view class="landing-hero__leaf landing-hero__leaf--one"></view>
      <view class="landing-hero__leaf landing-hero__leaf--two"></view>
      <view class="landing-hero__orb landing-hero__orb--one"></view>
      <view class="landing-hero__orb landing-hero__orb--two"></view>

      <view class="hero-display landing-title">选择要训练的<br />亚洲语种</view>
      <view class="body-copy landing-copy">越南语、泰语、马来语、印尼语、菲律宾语、印地语和泰米尔语都可以从免费试练开始。先听标准音，再录音评分，最后进入对应课程。</view>

      <view class="landing-actions">
        <view class="sanctuary-cta sanctuary-cta--primary" bindtap="startSelected">
          <text>开始当前语种</text>
          <view class="cta-arrow"></view>
        </view>
      </view>
    </view>

    <view class="landing-language-grid">
      <block wx:for="{{languages}}" wx:key="id">
        <view
          class="landing-language-card landing-language-card--{{item.tone}} {{selectedDialect === item.id ? 'landing-language-card--active' : ''}}"
          data-dialect="{{item.id}}"
          bindtap="selectLanguage"
        >
          <view class="landing-language-card__icon mini-symbol mini-symbol--{{item.icon}}"></view>
          <view class="landing-language-card__body">
            <view class="landing-language-card__name">{{item.name}}</view>
            <view class="landing-language-card__sub">{{item.sub}}</view>
          </view>
          <view class="landing-language-card__badge">{{item.unlocked ? '已开通' : '试练'}}</view>
        </view>
      </block>
    </view>

    <view class="surface-card landing-activate">
      <view class="landing-activate__head">
        <view>
          <view class="landing-activate__eyebrow">ACTIVATION</view>
          <view class="landing-activate__title">输入激活码开通当前语种</view>
        </view>
        <view class="landing-activate__chip">已选</view>
      </view>
      <view class="landing-activate__selected">
        <block wx:for="{{languages}}" wx:key="id">
          <text wx:if="{{selectedDialect === item.id}}">{{item.name}} · {{item.sub}}</text>
        </block>
      </view>
      <view class="landing-activate__form">
        <input
          class="landing-activate__input"
          value="{{activationCode}}"
          placeholder="输入对应语种激活码"
          placeholder-class="landing-activate__placeholder"
          bindinput="handleCodeInput"
        />
        <button class="landing-activate__button" loading="{{activationLoading}}" disabled="{{activationLoading}}" bindtap="activateCode">激活</button>
      </view>
      <view class="landing-activate__message" wx:if="{{activationMessage}}">{{activationMessage}}</view>
    </view>

    <view class="landing-scenery">
      <view class="landing-scenery__sun"></view>
      <view class="landing-scenery__mountain landing-scenery__mountain--left"></view>
      <view class="landing-scenery__mountain landing-scenery__mountain--right"></view>
      <view class="landing-scenery__river"></view>
      <view class="landing-scenery__leaf landing-scenery__leaf--left"></view>
      <view class="landing-scenery__leaf landing-scenery__leaf--right"></view>
      <view class="landing-scenery__mask"></view>
      <view class="landing-scenery__quote">“语言是开启另一种生活的钥匙。”</view>
    </view>

    <view class="landing-metrics">
      <view class="surface-wrap landing-metric landing-metric--score">
        <view class="landing-metric__icon metric-icon metric-icon--score"></view>
        <view class="landing-metric__value">8种</view>
        <view class="landing-metric__label">准确度 / 完整度 / 流利度</view>
      </view>
      <view class="surface-wrap landing-metric landing-metric--path">
        <view class="landing-metric__icon metric-icon metric-icon--path"></view>
        <view class="landing-metric__value">多套</view>
        <view class="landing-metric__label">按语种独立课程路径</view>
      </view>
    </view>

    <view class="section-head landing-section-head">
      <view class="section-title">怎么开始练</view>
      <view class="section-link" bindtap="startSelected">去试练</view>
    </view>

    <view class="landing-flow">
      <view class="surface-wrap landing-flow__item landing-flow__item--one">
        <view class="landing-flow__icon flow-icon flow-icon--dialect">
          <view class="flow-icon__book-left"></view>
          <view class="flow-icon__book-right"></view>
        </view>
        <view class="landing-flow__watermark flow-watermark flow-watermark--dialect">
          <view class="flow-watermark__book-left"></view>
          <view class="flow-watermark__book-right"></view>
          <view class="flow-watermark__leaf"></view>
        </view>
        <view class="landing-flow__num">01</view>
        <view class="landing-flow__title">先选一个语种</view>
        <view class="landing-flow__copy">想练哪个，就先点哪个。每个语种都可以先试一条。</view>
      </view>
      <view class="surface-wrap landing-flow__item landing-flow__item--two">
        <view class="landing-flow__icon flow-icon flow-icon--record">
          <view class="flow-icon__mic-head"></view>
          <view class="flow-icon__mic-stand"></view>
        </view>
        <view class="landing-flow__watermark flow-watermark flow-watermark--record">
          <view class="flow-watermark__mic-head"></view>
          <view class="flow-watermark__mic-stand"></view>
          <view class="flow-watermark__sound flow-watermark__sound--one"></view>
          <view class="flow-watermark__sound flow-watermark__sound--two"></view>
        </view>
        <view class="landing-flow__num">02</view>
        <view class="landing-flow__title">听一遍，再录一条</view>
        <view class="landing-flow__copy">先听范读，再按住录音，看看自己的发音反馈。</view>
      </view>
      <view class="surface-wrap landing-flow__item landing-flow__item--three">
        <view class="landing-flow__icon flow-icon flow-icon--unlock">
          <view class="flow-icon__lock-arc"></view>
          <view class="flow-icon__lock-body"></view>
        </view>
        <view class="landing-flow__watermark flow-watermark flow-watermark--unlock">
          <view class="flow-watermark__lock-arc"></view>
          <view class="flow-watermark__lock-body"></view>
          <view class="flow-watermark__spark flow-watermark__spark--one"></view>
          <view class="flow-watermark__spark flow-watermark__spark--two"></view>
        </view>
        <view class="landing-flow__num">03</view>
        <view class="landing-flow__title">有激活码就开通</view>
        <view class="landing-flow__copy">购买后把激活码填进来，就能进入对应语种课程。</view>
      </view>
    </view>
  </view>
</view>
