<view class="container">
  <view class="panel">
    <view class="section-title">绑定手机号</view>
    <view class="section-subtitle">用于开通完整版、识别账号和保存学习记录。</view>
    <input class="input mt-24" type="number" maxlength="11" placeholder="请输入手机号" bindinput="handleInput" value="{{phone}}" />
    <button class="btn-primary mt-24" bindtap="submit">确认绑定</button>
  </view>
</view>
