.page-home__content {
  padding-bottom: 220rpx;
}

.page-home__hero {
  padding-top: 4rpx;
}

.page-home__progress-shell {
  margin-top: 108rpx;
  padding: 64rpx 42rpx 58rpx;
  text-align: center;
}

.page-home__ring {
  position: relative;
  width: 250rpx;
  height: 250rpx;
  margin: 0 auto;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.page-home__ring::after {
  content: '';
  position: absolute;
  inset: 20rpx;
  border-radius: 50%;
  background: var(--surface-low);
}

.page-home__ring-center {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.page-home__ring-value {
  color: var(--on-surface);
  font-size: 54rpx;
  font-weight: 900;
  line-height: 1;
}

.page-home__ring-label {
  margin-top: 10rpx;
  color: var(--on-surface-variant);
  font-size: 18rpx;
  line-height: 1;
}

.page-home__progress-title {
  margin-top: 42rpx;
  color: var(--on-surface);
  font-size: 26rpx;
  font-weight: 900;
}

.page-home__progress-copy {
  margin-top: 16rpx;
  color: var(--on-surface-variant);
  font-size: 24rpx;
  line-height: 1.5;
}

.page-home__course-card {
  position: relative;
  margin-top: 50rpx;
  padding: 0;
  overflow: hidden;
}

.page-home__course-visual {
  position: relative;
  height: 300rpx;
  overflow: hidden;
}

.page-home__course-scenery {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 22% 20%, rgba(247, 180, 99, 0.78), transparent 14%),
    radial-gradient(circle at 78% 12%, rgba(209, 246, 225, 0.95), transparent 20%),
    radial-gradient(circle at 70% 72%, rgba(0, 107, 71, 0.68), transparent 24%),
    linear-gradient(135deg, #153725 0%, #147552 44%, #90d2a8 100%);
}

.page-home__course-scenery::before,
.page-home__course-scenery::after {
  content: '';
  position: absolute;
  bottom: -48rpx;
  width: 420rpx;
  height: 260rpx;
  border-radius: 52% 48% 0 0;
  background: rgba(12, 78, 48, 0.72);
}

.page-home__course-scenery::before {
  left: -160rpx;
}

.page-home__course-scenery::after {
  right: -150rpx;
  background: rgba(35, 115, 73, 0.68);
}

.page-home__course-badge {
  position: absolute;
  top: 34rpx;
  right: 34rpx;
  z-index: 2;
}

.page-home__course-body {
  padding: 42rpx 44rpx 50rpx;
}

.page-home__course-kicker {
  color: #7a3900;
  font-size: 24rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
}

.page-home__course-title {
  margin-top: 16rpx;
  color: var(--on-surface);
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.35;
}

.page-home__course-meta {
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-top: 34rpx;
  color: var(--on-surface-variant);
  font-size: 24rpx;
}

.learner-stack {
  display: flex;
  align-items: center;
  width: 68rpx;
}

.learner {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #ffffff;
  background:
    radial-gradient(circle at 50% 28%, #ffd9bf 0%, #ffd9bf 24%, transparent 25%),
    linear-gradient(180deg, #0d7d61 0%, #0d7d61 52%, #f1f4f2 53%, #f1f4f2 100%);
}

.learner--two {
  margin-left: -10rpx;
  background:
    radial-gradient(circle at 50% 28%, #ffd2b0 0%, #ffd2b0 24%, transparent 25%),
    linear-gradient(180deg, #2c7aa5 0%, #2c7aa5 52%, #f1f4f2 53%, #f1f4f2 100%);
}

.page-home__course-button {
  margin-top: 34rpx;
  color: #ffffff;
  background-color: #00875a;
  background-image: linear-gradient(135deg, #006b47 0%, #00875a 100%);
}

.page-home__course-accent {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: -2rpx;
  height: 4rpx;
  border-radius: 8rpx;
  background: #895100;
}

.page-home__section-head {
  margin-top: 92rpx;
  margin-bottom: 28rpx;
}

.page-home__tile-list {
  display: grid;
  grid-template-columns: 1fr;
  gap: 42rpx;
}

.page-home__tile {
  position: relative;
  min-height: 300rpx;
  padding: 44rpx;
  overflow: hidden;
}

.unit-icon {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary);
}

.unit-icon--warm {
  color: #895100;
  background: #efe4d7;
}

.unit-icon--green {
  color: var(--primary);
  background: #dff0e8;
}

.unit-icon--forest {
  color: #376653;
  background: #e0ebe6;
}

.unit-symbol {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  color: inherit;
}

.unit-symbol::before,
.unit-symbol::after {
  content: '';
  position: absolute;
  background: currentColor;
}

.unit-symbol--voice::before {
  left: 5rpx;
  top: 10rpx;
  width: 12rpx;
  height: 14rpx;
  border-radius: 4rpx;
}

.unit-symbol--voice::after {
  right: 3rpx;
  top: 5rpx;
  width: 16rpx;
  height: 24rpx;
  border-radius: 0 18rpx 18rpx 0;
  border-right: 5rpx solid currentColor;
  background: transparent;
}

.unit-symbol--book::before,
.unit-symbol--book::after {
  top: 4rpx;
  width: 15rpx;
  height: 25rpx;
  border-radius: 2rpx 8rpx 8rpx 2rpx;
  background: currentColor;
}

.unit-symbol--book::before { left: 1rpx; }
.unit-symbol--book::after { right: 1rpx; opacity: 0.7; }

.unit-symbol--temple::before {
  left: 4rpx;
  right: 4rpx;
  bottom: 4rpx;
  height: 16rpx;
  border-radius: 2rpx;
}

.unit-symbol--temple::after {
  left: 0;
  top: 5rpx;
  width: 0;
  height: 0;
  background: transparent;
  border-left: 17rpx solid transparent;
  border-right: 17rpx solid transparent;
  border-bottom: 15rpx solid currentColor;
}

.unit-watermark {
  position: absolute;
  top: 44rpx;
  right: 36rpx;
  width: 112rpx;
  height: 112rpx;
  opacity: 0.18;
  color: #3e4942;
}

.unit-watermark::before,
.unit-watermark::after {
  content: none;
}

.unit-watermark__shape {
  position: absolute;
  background: currentColor;
}

.unit-watermark--voice .unit-watermark__shape--a {
  left: 18rpx;
  top: 42rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 10rpx;
}

.unit-watermark--voice .unit-watermark__shape--b {
  right: 10rpx;
  top: 20rpx;
  width: 54rpx;
  height: 72rpx;
  border-radius: 0 54rpx 54rpx 0;
  border-right: 14rpx solid currentColor;
  background: transparent;
}

.unit-watermark--voice .unit-watermark__shape--c {
  left: 8rpx;
  bottom: 18rpx;
  width: 44rpx;
  height: 14rpx;
  border-radius: 14rpx;
}

.unit-watermark--book .unit-watermark__shape--a,
.unit-watermark--book .unit-watermark__shape--b {
  top: 14rpx;
  width: 50rpx;
  height: 82rpx;
  border-radius: 4rpx 22rpx 22rpx 4rpx;
}

.unit-watermark--book .unit-watermark__shape--a { left: 0; }
.unit-watermark--book .unit-watermark__shape--b { right: 0; opacity: 0.72; }
.unit-watermark--book .unit-watermark__shape--c {
  left: 52rpx;
  top: 18rpx;
  width: 8rpx;
  height: 76rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.7);
}

.unit-watermark--temple .unit-watermark__shape--a {
  left: 18rpx;
  right: 18rpx;
  bottom: 18rpx;
  height: 42rpx;
  border-radius: 3rpx;
}

.unit-watermark--temple .unit-watermark__shape--b {
  left: 0;
  top: 8rpx;
  width: 0;
  height: 0;
  background: transparent;
  border-left: 56rpx solid transparent;
  border-right: 56rpx solid transparent;
  border-bottom: 48rpx solid currentColor;
}

.unit-watermark--temple .unit-watermark__shape--c {
  left: 44rpx;
  bottom: 30rpx;
  width: 24rpx;
  height: 30rpx;
  border-radius: 16rpx 16rpx 4rpx 4rpx;
  background: rgba(255, 255, 255, 0.7);
}

.page-home__tile-title {
  margin-top: 86rpx;
  color: var(--on-surface);
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.3;
}

.page-home__tile-copy {
  margin-top: 16rpx;
  color: var(--on-surface-variant);
  font-size: 26rpx;
  line-height: 1.55;
}
