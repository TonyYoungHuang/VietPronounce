<view class="sanctuary-page with-tabbar page-home">
  <view class="topbar">
    <view class="avatar-shell" bindtap="goProfile">
      <view class="avatar-shell__core">{{avatarText}}</view>
    </view>
    <view class="topbar-spacer"></view>
    <view class="topbar-action" bindtap="goDialect">⚙</view>
  </view>

  <view class="container topbar-offset page-home__content">
    <view class="page-home__hero">
      <view class="hero-display">你好，<text class="hero-accent">{{heroName}}</text></view>
      <view class="body-copy">欢迎回到您的避风港。让我们继续您的越南语探索之旅。</view>
    </view>

    <view class="surface-wrap page-home__progress-shell">
      <view class="page-home__ring" style="{{ringStyle}}">
        <view class="page-home__ring-center">
          <view class="page-home__ring-value">{{overallPercent}}%</view>
          <view class="page-home__ring-label">今日进度</view>
        </view>
      </view>
      <view class="page-home__progress-title">每日目标</view>
      <view class="page-home__progress-copy">{{outstandingCount ? ('只差 ' + outstandingCount + ' 个项目可达成目标！') : '今天的学习状态很好，继续保持。'}}</view>
    </view>

    <view class="surface-card page-home__course-card">
      <view class="page-home__course-visual">
        <view class="page-home__course-scenery"></view>
        <view class="warm-badge page-home__course-badge">{{unlocked ? '正在学习' : '免费试练'}}</view>
      </view>
      <view class="page-home__course-body">
        <view class="page-home__course-kicker">{{selectedDialect === 'south' ? 'VIETNAMESE (SOUTH)' : 'VIETNAMESE (NORTH)'}}</view>
        <view class="page-home__course-title">{{currentCourseTitle}}</view>
        <view class="page-home__course-meta">
          <view class="learner-stack">
            <view class="learner learner--one"></view>
            <view class="learner learner--two"></view>
          </view>
          <text>与 2.4k 名学生共同学习</text>
        </view>
        <button class="btn-primary page-home__course-button" bindtap="goContinue">{{courseButtonText}} →</button>
      </view>
      <view class="page-home__course-accent"></view>
    </view>

    <view class="section-head page-home__section-head">
      <view class="section-title">推荐单元</view>
      <view class="section-link" bindtap="goLevels">查看全部</view>
    </view>

    <view class="page-home__tile-list">
      <block wx:for="{{tiles}}" wx:key="id">
        <view class="surface-wrap page-home__tile" data-action="{{item.action}}" bindtap="openTile">
          <view class="unit-icon unit-icon--{{item.tone}}">
            <view class="unit-symbol unit-symbol--{{item.icon}}"></view>
          </view>
          <view class="unit-watermark unit-watermark--{{item.icon}}">
            <view class="unit-watermark__shape unit-watermark__shape--a"></view>
            <view class="unit-watermark__shape unit-watermark__shape--b"></view>
            <view class="unit-watermark__shape unit-watermark__shape--c"></view>
          </view>
          <view class="page-home__tile-title">{{item.title}}</view>
          <view class="page-home__tile-copy">{{item.subtitle}}</view>
        </view>
      </block>
    </view>
  </view>
</view>
