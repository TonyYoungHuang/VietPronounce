.result-page {
  padding-bottom: 220rpx;
}

.result-page__content {
  padding-bottom: 240rpx;
}

.result-back {
  font-size: 62rpx;
  line-height: 1;
}

.result-hero {
  position: relative;
  width: 430rpx;
  height: 430rpx;
  margin: 8rpx auto 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-hero__halo {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background:
    radial-gradient(circle, rgba(0, 135, 90, 0.12) 0%, rgba(0, 135, 90, 0.12) 46%, transparent 47%),
    conic-gradient(from 20deg, rgba(0, 135, 90, 0.24), rgba(255, 220, 188, 0.72), rgba(0, 135, 90, 0.12), rgba(0, 135, 90, 0.24));
}

.result-hero__score-card {
  position: relative;
  z-index: 2;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 28rpx 76rpx rgba(25, 28, 27, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.result-hero__score {
  color: var(--primary);
  font-size: 120rpx;
  font-weight: 900;
  line-height: 0.95;
}

.result-hero__label {
  margin-top: 14rpx;
  color: rgba(0, 107, 71, 0.44);
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
}

.result-hero__leaf {
  position: absolute;
  z-index: 1;
  width: 112rpx;
  height: 112rpx;
  border-radius: 34rpx;
  background: linear-gradient(135deg, rgba(0, 135, 90, 0.2), rgba(141, 247, 193, 0.08));
  box-shadow: var(--shadow-soft);
}

.result-hero__leaf::after {
  content: '';
  position: absolute;
  left: 30rpx;
  top: 30rpx;
  width: 48rpx;
  height: 56rpx;
  border-radius: 48rpx 0 48rpx 48rpx;
  background: var(--primary);
  transform: rotate(45deg);
}

.result-hero__leaf--top {
  top: 14rpx;
  right: 6rpx;
  transform: rotate(12deg);
}

.result-hero__leaf--bottom {
  bottom: 26rpx;
  left: 2rpx;
  transform: rotate(-10deg);
  background: linear-gradient(135deg, rgba(137, 81, 0, 0.18), rgba(255, 220, 188, 0.82));
}

.result-hero__leaf--bottom::after {
  background: #895100;
}

.result-headline {
  margin-top: 28rpx;
  color: var(--on-surface);
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.18;
  text-align: center;
}

.result-subline {
  margin-top: 18rpx;
  color: var(--on-surface-variant);
  font-size: 28rpx;
  line-height: 1.7;
  text-align: center;
}

.result-delta-chip {
  max-width: 520rpx;
  min-height: 48rpx;
  margin: 24rpx auto 0;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  color: #006b47;
  background: rgba(0, 107, 71, 0.1);
  font-size: 24rpx;
  font-weight: 900;
}

.result-next-card {
  margin-top: 42rpx;
  padding: 36rpx 34rpx;
  overflow: hidden;
}

.result-next-card__label {
  display: inline-flex;
  min-height: 44rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  color: #683d00;
  background: #ffdcbc;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.result-next-card__title {
  margin-top: 24rpx;
  color: #006b47;
  font-size: 64rpx;
  font-weight: 900;
  line-height: 1;
}

.result-next-card__copy {
  margin-top: 22rpx;
  color: #191c1b;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.4;
}

.result-next-card__tip {
  margin-top: 12rpx;
  color: #3e4942;
  font-size: 25rpx;
  line-height: 1.65;
}

.result-segment-card {
  margin-top: 42rpx;
  padding: 34rpx 32rpx;
}

.result-segment-card__title {
  color: #191c1b;
  font-size: 32rpx;
  font-weight: 900;
}

.result-segment-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.result-segment {
  min-height: 64rpx;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #3e4942;
  background: #f2f4f2;
  font-size: 28rpx;
  font-weight: 800;
}

.result-segment--active {
  color: #ffffff;
  background: linear-gradient(135deg, #895100, #b97210);
  box-shadow: 0 14rpx 28rpx rgba(137, 81, 0, 0.16);
}

.result-segment-tip {
  margin-top: 26rpx;
  padding: 26rpx;
  border-radius: 34rpx;
  background: #fff4e9;
}

.result-segment-tip__label {
  color: #895100;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.result-segment-tip__copy {
  margin-top: 12rpx;
  color: #3e4942;
  font-size: 26rpx;
  line-height: 1.65;
}

.result-metrics {
  display: grid;
  grid-template-columns: 1fr;
  gap: 26rpx;
  margin-top: 54rpx;
}

.result-metric-card {
  padding: 34rpx 36rpx;
  border-radius: 40rpx;
}

.result-metric-card__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.result-metric-card__title {
  color: var(--on-surface);
  font-size: 30rpx;
  font-weight: 900;
}

.result-metric-card__icon {
  position: relative;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(0, 107, 71, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #006b47;
  font-size: 24rpx;
  font-weight: 900;
}

.result-metric-card__icon::before {
  content: none;
}

.result-metric-card--warm .result-metric-card__icon {
  background: rgba(137, 81, 0, 0.12);
}

.result-metric-card--warm .result-metric-card__icon::before {
  content: none;
}

.result-metric-card__value {
  margin-top: 22rpx;
  color: var(--on-surface);
  font-size: 72rpx;
  font-weight: 900;
  line-height: 1;
}

.result-metric-card__value text {
  margin-left: 4rpx;
  font-size: 30rpx;
}

.result-metric-card__bar {
  height: 10rpx;
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: var(--surface-high);
  overflow: hidden;
}

.result-metric-card__fill {
  height: 100%;
  border-radius: 999rpx;
  background-color: #00875a;
  background-image: linear-gradient(135deg, #006b47, #00875a);
}

.result-metric-card--warm .result-metric-card__fill {
  background: linear-gradient(135deg, #895100, #fea129);
}

.result-dimensions {
  margin-top: 58rpx;
}

.result-dimensions__head {
  margin-top: 0;
  margin-bottom: 24rpx;
}

.result-dimension-card {
  margin-top: 22rpx;
  padding: 30rpx 32rpx;
  border-radius: 40rpx;
  overflow: hidden;
}

.result-dimension-card:active {
  transform: scale(0.99);
}

.result-repeat-card {
  margin-top: 50rpx;
  padding: 36rpx 32rpx;
}

.result-repeat-card__title {
  color: #191c1b;
  font-size: 34rpx;
  font-weight: 900;
}

.result-repeat-step {
  display: flex;
  gap: 18rpx;
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 30rpx;
  background: #f2f4f2;
}

.result-repeat-step__label {
  flex: 0 0 88rpx;
  color: #895100;
  font-size: 23rpx;
  font-weight: 900;
}

.result-repeat-step__text {
  flex: 1;
  color: #3e4942;
  font-size: 24rpx;
  line-height: 1.55;
}

.result-dimension-card__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.result-dimension-card__label {
  color: #191c1b;
  font-size: 30rpx;
  font-weight: 900;
}

.result-dimension-card__focus {
  margin-top: 8rpx;
  color: #895100;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.35;
}

.result-dimension-card__score {
  flex: 0 0 72rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: #00875a;
  font-size: 30rpx;
  font-weight: 900;
}

.result-dimension-card__bar {
  height: 10rpx;
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: #dfe6e2;
  overflow: hidden;
}

.result-dimension-card__fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #006b47, #00875a);
}

.result-dimension-card__tip {
  margin-top: 22rpx;
  color: #3e4942;
  font-size: 25rpx;
  line-height: 1.65;
}

.result-attempts {
  margin-top: 58rpx;
}

.result-attempts__head {
  margin-top: 0;
  margin-bottom: 24rpx;
}

.result-attempts__panel {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  padding: 30rpx 26rpx;
  border-radius: 40rpx;
}

.result-attempt {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.result-attempt__score {
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: #006b47;
  font-size: 28rpx;
  font-weight: 900;
}

.result-attempt__label {
  color: #3e4942;
  font-size: 21rpx;
  font-weight: 800;
}

.result-tip-card {
  position: relative;
  margin-top: 46rpx;
  padding: 42rpx 40rpx 150rpx;
  border-radius: 44rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #fff4e9 0%, #f7eadb 100%);
  box-shadow: inset 0 -4rpx 0 #dfcfb6;
}

.result-tip-card__label {
  display: inline-flex;
  min-height: 44rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  color: #683d00;
  background: #ffdcbc;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.result-tip-card__title {
  margin-top: 28rpx;
  color: #3f2200;
  font-size: 36rpx;
  font-weight: 900;
}

.result-tip-card__item {
  margin-top: 18rpx;
  color: #6b420f;
  font-size: 28rpx;
  line-height: 1.75;
}

.result-tip-card__stamp {
  position: absolute;
  right: -20rpx;
  bottom: -24rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at 50% 50%, #fea129 0%, #fea129 28%, transparent 29%),
    radial-gradient(circle at 50% 50%, rgba(137, 81, 0, 0.2) 0%, rgba(137, 81, 0, 0.2) 58%, transparent 59%);
  opacity: 0.86;
}

.result-audio-row {
  display: flex;
  gap: 18rpx;
  margin-top: 32rpx;
}

.result-audio-row .btn-secondary,
.result-audio-row .btn-ghost {
  flex: 1;
  min-height: 82rpx;
  font-size: 26rpx;
}

.result-action-bar {
  position: fixed;
  left: 36rpx;
  right: 36rpx;
  bottom: 28rpx;
  z-index: 60;
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 18rpx;
  padding: 16rpx;
  border-radius: 44rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(18px);
  box-shadow: 0 -12rpx 38rpx rgba(0, 107, 71, 0.1);
}

.result-action {
  min-height: 92rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
}

.result-action--ghost {
  color: #191c1b;
  background-color: #f2f4f2;
  background-image: none;
}

.result-action--primary {
  color: #ffffff;
  background-color: #00875a;
  background-image: linear-gradient(135deg, #006b47 0%, #00875a 100%);
  box-shadow: 0 18rpx 34rpx rgba(0, 107, 71, 0.22);
}

button.result-action--ghost {
  color: #191c1b;
}

button.result-action--primary {
  color: #ffffff;
  background-color: #00875a;
}
