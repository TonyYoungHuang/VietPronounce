.auth-page__content { padding-bottom: 180rpx; }
.auth-hero { padding-top: 18rpx; }
.auth-card { margin-top: 72rpx; padding: 52rpx 42rpx; text-align: center; overflow: hidden; }
.auth-card__icon {
  position: relative;
  width: 128rpx;
  height: 128rpx;
  margin: 0 auto 34rpx;
  border-radius: 50%;
  background: #dff0e8;
}
.auth-card__icon::before {
  content: '';
  position: absolute;
  left: 40rpx;
  top: 30rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #006b47;
}
.auth-card__icon::after {
  content: '';
  position: absolute;
  left: 30rpx;
  bottom: 28rpx;
  width: 68rpx;
  height: 38rpx;
  border-radius: 38rpx 38rpx 18rpx 18rpx;
  background: #006b47;
}
